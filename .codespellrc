[codespell]
skip = node_modules,reports,.svelte-kit,build,dist,bun.lock,package-lock.json,*.lock,*.min.js,*.min.css

# Indonesian locale false positives — valid Bahasa Indonesia words
ignore-words-list =
  progres,
  profesional,
  simbol,
  faktor,
  Faktor,
  lokal,
  maks,
  poin,
  afterAll,
  re-use

# Only check source files
check-filenames = false
